PORT=3004
NODE_ENV=development
SERVICE_ID=booking-service

# MongoDB - SỬA DÒNG NÀY (thêm /booking?authSource=admin)
MONGODB_URI=mongodb://admin:password123@localhost:27017
MONGODB_DB_NAME=booking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password123

# RabbitMQ
RABBITMQ_URL=amqp://admin:password123@localhost:5672

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Internal Services - QUAN TRỌNG: Đường dẫn đầy đủ
DRIVER_SERVICE_URL=http://localhost:3003
PRICING_SERVICE_URL=http://localhost:3008
INTERNAL_API_KEY=internal-key