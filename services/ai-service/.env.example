# Service
PORT=3011
NODE_ENV=development
SERVICE_ID=ai-service

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password123

# RabbitMQ
RABBITMQ_URL=amqp://admin:password123@localhost:5672

# JWT
JWT_SECRET=your-super-secret-jwt-key-2024

# Model paths
ETA_MODEL_PATH=./models/eta-model
SURGE_MODEL_PATH=./models/surge-model
DRIVER_MODEL_PATH=./models/driver-model
FRAUD_MODEL_PATH=./models/fraud-model

# Training config
TRAINING_EPOCHS=50
TRAINING_BATCH_SIZE=32
